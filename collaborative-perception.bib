@article{PillarAttentionEncoder-2024-bai,
  title = {Pillar {{Attention Encoder}} for {{Adaptive Cooperative Perception}}},
  author = {Bai, Zhengwei and Wu, Guoyuan and Barth, Matthew J. and Qiu, Hang and Liu, Yongkang and Sisbot, Emrah Akin and Oguchi, Kentaro},
