  file = {/home/lei-wan/Zotero/storage/IQPJNFUK/Shi et al_2023_MCoT.pdf},
  isbn = {979-8-3503-3071-7},
  keywords = {CP-Camera,CP-Intermeidate,CP-LiDAR,CP-Object Detection},
  langid = {english},
  month = {December},
  pages = {1612--1619},
  publisher = {IEEE},
  shorttitle = {{{MCoT}}},
