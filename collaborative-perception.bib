  keywords = {CP-Intermeidate,CP-LiDAR,CP-Object Detection,issue paper (less about CP)},
  file = {/home/lei-wan/Zotero/storage/S7894QHM/Guo et al_2022_Slim-FCP.pdf}
}

@article{SoftActorCriticBased-2022-xiea,
  title = {Soft {{Actor}}--{{Critic-Based Multilevel Cooperative Perception}} for {{Connected Autonomous Vehicles}}},
  author = {Xie, Qi and Zhou, Xiaobo and Qiu, Tie and Zhang, Qingyu and Qu, Wenyu},
  year = {2022},
