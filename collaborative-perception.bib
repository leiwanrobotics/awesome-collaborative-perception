  doi = {10.1109/CVPR52729.2023.00531},
  file = {/home/lei-wan/Zotero/storage/YMRXFFX7/Yu et al_2023_V2X-Seq.pdf},
  isbn = {979-8-3503-0129-8},
  keywords = {CP-Camera,CP-Dataset,CP-LiDAR, CP-V2I},
  langid = {english},
