  month = {October},
  number = {4},
  pages = {10914--10921},
  shorttitle = {{{V2X-Sim}}},
  title = {{{V2X-Sim}}: {{Multi-Agent Collaborative Perception Dataset}} and {{Benchmark}} for {{Autonomous Driving}}},
  urldate = {2024-05-09},
  volume = {7},
