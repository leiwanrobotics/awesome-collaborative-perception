  shorttitle = {{{HoloVIC}}},
  title = {{{HoloVIC}}: {{Large-scale Dataset}} and {{Benchmark}} for {{Multi-Sensor Holographic Intersection}} and {{Vehicle-Infrastructure Cooperative}}},
