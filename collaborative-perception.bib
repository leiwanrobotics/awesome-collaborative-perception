  publisher = {IEEE},
  shorttitle = {{{OPV2V}}},
  title = {{{OPV2V}}: {{An Open Benchmark Dataset}} and {{Fusion Pipeline}} for {{Perception}} with {{Vehicle-to-Vehicle Communication}}},
