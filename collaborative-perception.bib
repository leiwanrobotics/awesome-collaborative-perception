  keywords = {CP-Intermeidate,CP-LiDAR,CP-Object Detection},
  langid = {english},
  month = {November},
  pages = {1--6},
  publisher = {IEEE},
  title = {Multi-{{Modal Virtual-Real Fusion}} Based {{Transformer}} for {{Collaborative Perception}}},
