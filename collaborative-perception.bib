  keywords = {CP-Intermeidate,CP-LiDAR,CP-Semantic Segmentation},
  langid = {english},
  month = {October},
  pages = {1--5},
  publisher = {IEEE},
  title = {A {{LiDAR Semantic Segmentation Framework}} for the {{Cooperative Vehicle-Infrastructure System}}},
