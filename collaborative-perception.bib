  file = {/home/lei-wan/Zotero/storage/2CM8RWY3/Wang et al_2022_Pillar-Based Cooperative Perception from Point Clouds for 6G-Enabled.pdf},
  issn = {1530-8677, 1530-8669},
  journal = {Wireless Communications and Mobile Computing},
  keywords = {CP-Early,CP-LiDAR,CP-Object Detection},
  langid = {english},
  month = {July},
  pages = {1--13},
  title = {Pillar-{{Based Cooperative Perception}} from {{Point Clouds}} for {{6G-Enabled Cooperative Autonomous Vehicles}}},
  urldate = {2024-05-03},
