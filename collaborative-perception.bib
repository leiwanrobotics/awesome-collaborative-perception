  author = {Guo, Jingda and Carrillo, Dominic and Tang, Sihai and Chen, Qi and Yang, Qing and Fu, Song and Wang, Xi and Wang, Nannan and Palacharla, Paparao},
  year = {2021},
  month = jul,
  journal = {IEEE Internet of Things Journal},
  volume = {8},
